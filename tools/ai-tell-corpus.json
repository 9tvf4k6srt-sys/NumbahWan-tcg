{
  "version": "1.1.0",
  "description": "Banned phrases that signal LLM-authored copy. Maintain by adding any phrase a reviewer flagged in PR review. Each entry is a regex (case-insensitive unless noted). Source column records why it's banned so future maintainers don't add a benign rewrite. v1.1 expanded from the 2026 zero-trace guide.",
  "lastUpdated": "2026-05-01",
  "scope": {
    "include": ["public/**/*.html", "public/**/*.md"],
    "exclude": [
      "public/static/research-md/**",
      "public/research/**",
      "public/*-legacy.html",
      "public/*-old.html",
      "public/card-audit.html",
      "public/trailer/review.html",
      "public/**/*.bak",
      "public/**/*-backup-*"
    ],
    "perRule": {
      "AIT-EN-FILLER:synergy": {
        "exclude": [
          "public/battle.html",
          "public/guild-siege.html",
          "public/games/**",
          "public/world/castle.html"
        ],
        "note": "TCG card synergy is real game-mechanics terminology, not LLM filler."
      },
      "AIT-ZH-CALQUE:卷軸": {
        "exclude": [
          "public/research.html",
          "public/research/**",
          "public/world/**",
          "public/museum/**"
        ],
        "note": "卷軸 in lore/world pages is an in-game artifact (paper scroll), not the UI metaphor calque."
      },
      "AIT-EN-FILLER:represents a pivotal moment": {
        "exclude": [
          "public/museum/exhibit-001.html"
        ],
        "note": "Lives inside <quote-block> attributed expert-quotes — fictional in-world voices for the Zakum Helmet exhibit. Reviewer kept verbatim because rewriting changes the in-character voice."
      },
      "AIT-EN-EMDASH-FLOOD": {
        "exclude": [
          "public/boss-dungeon.html",
          "public/world/castle.html",
          "public/world/dlc-12-abyssal-temple.html"
        ],
        "note": "Thai (กำแพงเพลิง / เฟส) and game-lore phase markers use a hyphen-style separator that visually trips the em-dash flood pattern. These pages are vetted lore content."
      }
    },
    "note": "research-md is an auto-generated academic-paper corpus we do not author; legacy/old/audit pages are read-only history."
  },
  "rules": [
    {
      "id": "AIT-EN-FILLER",
      "lang": "en",
      "severity": "high",
      "patterns": [
        "\\bdelve into\\b",
        "\\bdive deep into\\b",
        "\\bever-evolving\\b",
        "\\bever-changing landscape\\b",
        "\\bin (?:today's|the modern) (?:fast-paced |digital )?world\\b",
        "\\btapestry of\\b",
        "\\bnavigate the complexities\\b",
        "\\bcutting-edge\\b",
        "\\bstate-of-the-art\\b",
        "\\bgame-changer\\b",
        "\\bgame[ -]changing\\b",
        "\\bunlock the (?:potential|power) of\\b",
        "\\bharness the power of\\b",
        "\\bleverage(?:s|d|ing)? (?:the|our|your) (?:power|capabilities|strengths)\\b",
        "\\bseamlessly integrat(?:e|ed|es|ing)\\b",
        "\\bin a world where\\b",
        "\\bat the forefront of\\b",
        "\\brevolutionize (?:the way|how) (?:we|you)\\b",
        "\\bparadigm shift\\b",
        "\\bsynergize\\b",
        "\\bsynergy\\b",
        "\\bholistic approach\\b",
        "\\bbespoke solution\\b",
        "\\brobust (?:framework|solution|platform)\\b",
        "\\bcomprehensive (?:suite|framework|solution)\\b",
        "\\bbrand in the wild\\b",
        "\\b(?:represents|marks|is) a pivotal (?:moment|step)\\b",
        "\\bpivotal (?:role|piece) in (?:our|the|its)\\b",
        "\\bfurthermore,\\b",
        "\\bmoreover,\\b",
        "\\bin conclusion,\\b",
        "\\bit is (?:important|worth|crucial) (?:to (?:note|remember|highlight)|noting)\\b",
        "\\bunderscore(?:s|d)? the (?:importance|need|fact)\\b",
        "\\bvibrant (?:community|ecosystem|tapestry|culture|world)\\b",
        "\\bshowcase(?:s|d|ing)? (?:the|our|your) (?:best|finest|talent|capabilities)\\b",
        "\\belevate (?:your|the) (?:experience|game|brand|journey)\\b",
        "\\bcraft(?:ed|ing)? (?:meticulously|with care|with precision)\\b",
        "\\bmeticulously (?:crafted|designed|curated)\\b",
        "\\bresonate(?:s|d) with\\b",
        "\\bstand(?:s)? as a (?:beacon|testament|hallmark)\\b"
      ],
      "note": "Generic LLM filler. Replace with concrete subject + verb."
    },
    {
      "id": "AIT-EN-EXALTATION",
      "lang": "en",
      "severity": "medium",
      "patterns": [
        "\\bjourney through\\b",
        "\\bembark on (?:a|the) journey\\b",
        "\\bembark on this\\b",
        "\\bwhere art meets science\\b",
        "\\bbridge the gap between\\b",
        "\\btestament to\\b",
        "\\ba symphony of\\b",
        "\\bbreathe new life into\\b",
        "\\bfoster (?:innovation|collaboration|community)\\b",
        "\\bempower(?:s|ed|ing)? (?:individuals|users|creators)\\b",
        "\\bunwavering commitment\\b",
        "\\bredefin(?:e|es|ing) (?:the|what)\\b",
        "\\ba (?:rich|fascinating|captivating) (?:tapestry|blend|fusion)\\b",
        "\\binvite(?:s|d)? you to (?:explore|discover|join)\\b",
        "\\bweav(?:e|es|ing) (?:a|the|together)\\b"
      ],
      "note": "Inspirational filler. Show the thing instead."
    },
    {
      "id": "AIT-EN-EMDASH-FLOOD",
      "lang": "en",
      "severity": "low",
      "patterns": [
        "—[^—\\n<>]{1,40}—[^—\\n<>]{1,40}—[^—\\n<>]{1,40}—"
      ],
      "note": "Four or more em-dashes within ~120 characters with no HTML break = machine rhythm. Single or paired em-dashes in human writing are fine; cluster flooding is the tell."
    },
    {
      "id": "AIT-ZH-CALQUE",
      "lang": "zh",
      "severity": "high",
      "patterns": [
        "投資論述",
        "投資テーゼ",
        "卷軸",
        "用數字,不用敘事",
        "用数字,不用叙事",
        "在法規軌道上跑",
        "經不起陽光的流程",
        "经不起阳光的流程",
        "你的會計師會喜歡的數學",
        "你的会计师会喜欢的数学",
        "我們最後吃",
        "我们最后吃",
        "鎖定終身(?!\\s*[A-Za-z0-9])",
        "锁定终身(?!\\s*[A-Za-z0-9])",
        "急がない午後",
        "行く先のない時間",
        "經得起陽光",
        "经得起阳光"
      ],
      "note": "Direct English-to-Chinese calques. Rewrite in idiomatic 繁中 / 简中."
    },
    {
      "id": "AIT-ZH-AI-BUZZ",
      "lang": "zh",
      "severity": "medium",
      "patterns": [
        "賦能",
        "赋能",
        "閉環",
        "闭环",
        "顆粒度",
        "颗粒度",
        "對齊一下",
        "对齐一下",
        "底層邏輯",
        "底层逻辑",
        "拉齊認知",
        "拉齐认知",
        "落地實踐",
        "落地实践",
        "打造一個生態",
        "打造一个生态",
        "深度賦能",
        "深度赋能",
        "全鏈路",
        "全链路",
        "新物種",
        "新物种"
      ],
      "note": "Internet-MBA Chinese. Speak like a person."
    },
    {
      "id": "AIT-JA-CALQUE",
      "lang": "ja",
      "severity": "high",
      "patterns": [
        "投資テーゼ",
        "巻物",
        "数字、ナラティブではなく",
        "ナラティブではなく",
        "暗号の空気感ではなく",
        "我々は最後に食べる",
        "我々は最後に食べる",
        "日光に耐えぬプロセス",
        "会計士が頷く算数",
        "アイデンティティはスライド",
        "ブランド・イン・ザ・ワイルド",
        "急がない午後、行く先のない時間",
        "試作条件への同意",
        "ドローダウンは工学、希望ではない"
      ],
      "note": "Direct English-to-Japanese calques and over-poetic translation-ese."
    },
    {
      "id": "AIT-JA-OVERFORMAL",
      "lang": "ja",
      "severity": "medium",
      "patterns": [
        "〜ものだ",
        "〜である\\s*$",
        "〜と言えるでしょう",
        "〜ではないでしょうか",
        "〜と考えられます",
        "言わば",
        "謂わば",
        "畢竟",
        "蓋し"
      ],
      "note": "Old-formal closing patterns. Modern editorial Japanese prefers です/ます or assertive plain."
    }
  ]
}
