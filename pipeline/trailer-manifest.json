{
  "$schema": "NWG Trailer Pipeline — Manifest Format v1",
  "$doc": "Each trailer is a sequence of scenes. Each scene references an image or video, has timing, caption, and transition info. The pipeline reads this manifest and produces a final video with synced music and burned-in captions.",

  "meta": {
    "title": "NWG Cinematic Trailer — Castle Reveal",
    "aspect_ratio": "16:9",
    "resolution": "1280x720",
    "fps": 24,
    "duration_target_seconds": 60,
    "music_style": "Epic orchestral with drums, building intensity, cinematic trailer music",
    "music_bpm_target": 110,
    "caption_style": {
      "font": "Rajdhani",
      "weight": 700,
      "color": "#FFD700",
      "shadow": "0 0 20px rgba(255,215,0,0.5), 2px 2px 4px rgba(0,0,0,0.9)",
      "position": "bottom-center",
      "animation": "fade-up"
    }
  },

  "scenes": [
    {
      "id": "s01",
      "type": "image-to-video",
      "source": "/static/game/01-title-cinematic.webp",
      "duration": 6,
      "camera": "slow-zoom-out",
      "caption": "In a world where every creature has a soul...",
      "caption_delay": 1.0,
      "caption_duration": 4.0,
      "transition_out": "cut-on-beat",
      "music_cue": "intro-soft-strings"
    },
    {
      "id": "s02",
      "type": "image-to-video",
      "source": "/static/game/02-open-world.webp",
      "duration": 5,
      "camera": "slow-pan-right",
      "caption": "A guild built an empire",
      "caption_delay": 0.5,
      "caption_duration": 3.5,
      "transition_out": "cut-on-beat"
    },
    {
      "id": "s03",
      "type": "video",
      "source": "/static/video/scene1-castle-reveal.mp4",
      "trim": { "start": 0, "end": 6 },
      "caption": "CASTLE NUMBAHWAN",
      "caption_delay": 1.0,
      "caption_duration": 3.0,
      "caption_style_override": { "size": "large", "animation": "scale-in" },
      "transition_out": "cut-on-beat",
      "music_cue": "first-beat-drop"
    },
    {
      "id": "s04",
      "type": "image-to-video",
      "source": "/static/game/05-card-battle.webp",
      "duration": 5,
      "camera": "slow-zoom-in",
      "caption": "Where card duels decide fate",
      "caption_delay": 0.5,
      "caption_duration": 3.5,
      "transition_out": "cut-on-beat"
    },
    {
      "id": "s05",
      "type": "video",
      "source": "/static/video/scene2-card-duel.mp4",
      "trim": { "start": 0, "end": 6 },
      "caption": "",
      "transition_out": "flash-white"
    },
    {
      "id": "s06",
      "type": "image-to-video",
      "source": "/static/game/17-monkey-king-boss.webp",
      "duration": 5,
      "camera": "slow-zoom-in",
      "caption": "80+ companions fight beside you",
      "caption_delay": 0.5,
      "caption_duration": 4.0,
      "transition_out": "cut-on-beat",
      "music_cue": "crescendo-peak"
    },
    {
      "id": "s07",
      "type": "video",
      "source": "/static/video/scene4-monkey-king.mp4",
      "trim": { "start": 1, "end": 6 },
      "caption": "MONKEY KING — PHASE 2",
      "caption_style_override": { "color": "#FF4444", "size": "large" },
      "transition_out": "cut-on-beat"
    },
    {
      "id": "s08",
      "type": "image-to-video",
      "source": "/static/game/55-sky-islands.webp",
      "duration": 5,
      "camera": "slow-dolly-forward",
      "caption": "6 massive FREE DLCs",
      "caption_delay": 0.5,
      "caption_duration": 3.0,
      "transition_out": "cut-on-beat"
    },
    {
      "id": "s09",
      "type": "video",
      "source": "/static/video/scene5-regina-storm.mp4",
      "trim": { "start": 0, "end": 6 },
      "caption": "A real 1907 shipwreck",
      "caption_delay": 1.0,
      "caption_duration": 4.0,
      "transition_out": "cut-on-beat",
      "music_cue": "chaos-drums"
    },
    {
      "id": "s10",
      "type": "image-to-video",
      "source": "/static/game/42-hell-realm.webp",
      "source_fallback": "/static/game/08-dungeon-raid.webp",
      "duration": 5,
      "camera": "slow-zoom-in",
      "caption": "Kill creatures and the wheel of Samsara turns",
      "caption_delay": 0.5,
      "caption_duration": 4.0,
      "transition_out": "fade-to-black",
      "music_cue": "quiet-tension"
    },
    {
      "id": "s11",
      "type": "title-card",
      "background": "#000000",
      "duration": 4,
      "caption": "THE CYCLE CONTINUES...",
      "caption_style_override": {
        "color": "#FFD700",
        "size": "xlarge",
        "animation": "fade-in-slow",
        "font": "Orbitron"
      },
      "transition_out": "fade-to-black",
      "music_cue": "final-note-sustain"
    }
  ],

  "$pipeline_notes": {
    "step1_generate_clips": "For each 'image-to-video' scene, use AI video generation (Kling v3 / Veo3) with the camera motion prompt. For 'video' scenes, just trim the existing clip.",
    "step2_generate_music": "Generate music using the meta.music_style prompt, targeting meta.duration_target_seconds length. Use Mureka/ElevenLabs music generation.",
    "step3_analyze_beats": "Extract beat timestamps from the generated music. Align scene cuts to the nearest beat.",
    "step4_burn_captions": "Use FFmpeg to burn captions with the specified style, timing, and animation.",
    "step5_assemble": "Concatenate all clips with transitions, overlay the music track, and export final MP4.",
    "step6_compress": "Two-pass H.264 encode at 1.5 Mbps for web delivery, fast-start (moov atom at front)."
  }
}
