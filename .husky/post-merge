#!/bin/sh
# ═══════════════════════════════════════════════════════════════════
# Mycelium Pipeline: post-merge — WATCH + LEARN + FIX for merged commits
# ═══════════════════════════════════════════════════════════════════
#
# Without this, commits arriving via PR merge are invisible to learning.
# Fires after: git pull, git merge, PR merge-back
# ═══════════════════════════════════════════════════════════════════

# ─── STEP 1: WATCH + LEARN (sync all new commits) ───
if [ -f "mycelium-watch.cjs" ]; then
  node "mycelium-watch.cjs" --sync 2>/dev/null || true
fi
if [ -f "mycelium.cjs" ]; then
  node mycelium.cjs --sync 2>/dev/null || true
fi

# ─── STEP 2+3: FIX + VERIFY ───
if [ -f "mycelium-fix.cjs" ]; then
  node "mycelium-fix.cjs" --silent 2>/dev/null || true
fi

exit 0
