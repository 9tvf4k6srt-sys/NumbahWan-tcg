#!/bin/sh
# NW-MEMORY + gitwise: Pre-commit — enforce protocol, auto-guard, compact, warn
# Mile 3: constraints now BLOCK bad commits via --enforce

# ─── gitwise: warn about known risks (zero config, always runs) ───
if [ -f "gitwise.cjs" ]; then
  node "gitwise.cjs" --warn 2>/dev/null >&2 || true
fi

# ─── NW-MEMORY: protocol enforcement + guard ───
if [ ! -f "nw-memory.cjs" ]; then exit 0; fi

# Session marker must exist
if [ ! -f ".nw-session" ]; then
  echo "" >&2
  echo "  BLOCKED: No .nw-session file." >&2
  echo "  Run: cat .nw-context && echo \$(date +%s) > .nw-session" >&2
  echo "" >&2
  exit 1
fi

# Auto-compact if needed
MEM_SIZE=$(wc -c < memory.json 2>/dev/null || echo 0)
if [ "$MEM_SIZE" -gt 204800 ]; then
  node nw-memory.cjs --compact >/dev/null 2>&1
fi

git add memory.json 2>/dev/null || true

# Auto-guard with ENFORCEMENT: constraints actively block bad commits
# Shows warnings for areas being touched AND blocks if violations detected
node nw-memory.cjs --guard --enforce 2>&1 >&2
GUARD_EXIT=$?
if [ "$GUARD_EXIT" -ne 0 ]; then
  echo "" >&2
  echo "  PRE-COMMIT BLOCKED: Constraint violations detected." >&2
  echo "  Review the warnings above and address them." >&2
  echo "  Bypass: git commit --no-verify" >&2
  echo "" >&2
  exit 1
fi

exit 0
