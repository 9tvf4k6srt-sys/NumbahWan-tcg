#!/bin/sh
# Mycelium: Pre-commit — enforce protocol, auto-guard, compact, warn
# The underground network protects before every commit

# ─── Mycelium Watch: warn about known risks (zero config, always runs) ───
if [ -f "mycelium-watch.cjs" ]; then
  node "mycelium-watch.cjs" --warn 2>/dev/null >&2 || true
fi

# ─── Mycelium Core: protocol enforcement + guard ───
if [ ! -f "mycelium.cjs" ]; then exit 0; fi

# Session marker must exist
if [ ! -f ".mycelium-session" ]; then
  echo "" >&2
  echo "  BLOCKED: No .mycelium-session file." >&2
  echo "  Run: cat .mycelium-context && echo \$(date +%s) > .mycelium-session" >&2
  echo "" >&2
  exit 1
fi

# Auto-compact if needed
MEM_SIZE=$(wc -c < .mycelium/memory.json 2>/dev/null || echo 0)
if [ "$MEM_SIZE" -gt 204800 ]; then
  node mycelium.cjs --compact >/dev/null 2>&1
fi

git add .mycelium/memory.json 2>/dev/null || true

# Auto-guard with ENFORCEMENT: constraints actively block bad commits
# Shows warnings for areas being touched AND blocks if violations detected
node mycelium.cjs --guard --enforce 2>&1 >&2
GUARD_EXIT=$?
if [ "$GUARD_EXIT" -ne 0 ]; then
  echo "" >&2
  echo "  PRE-COMMIT BLOCKED: Constraint violations detected." >&2
  echo "  Review the warnings above and address them." >&2
  echo "  Bypass: git commit --no-verify" >&2
  echo "" >&2
  exit 1
fi


