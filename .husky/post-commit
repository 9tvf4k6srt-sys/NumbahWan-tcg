#!/bin/sh
# ═══════════════════════════════════════════════════════════════════
# Mycelium Pipeline: commit → WATCH → LEARN → FIX → VERIFY
# ═══════════════════════════════════════════════════════════════════
#
# Three roles, working in sync:
#   1. WATCHER:    mycelium-watch --learn (commit intelligence)
#   2. LEARNER:    mycelium snapshot (memory + constraints)
#   3. FIXER:      mycelium-fix (diagnose → prescribe → fix → verify)
#
# No manual intervention ever needed.
# ═══════════════════════════════════════════════════════════════════

# ─── STEP 1: WATCH + LEARN (both systems observe this commit) ───
if [ -f "mycelium-watch.cjs" ]; then
  node "mycelium-watch.cjs" --learn 2>/dev/null || true
fi
if [ -f "mycelium.cjs" ]; then
  node mycelium.cjs >/dev/null 2>&1 || true
  node mycelium.cjs --brief >/dev/null 2>&1 || true
fi

# ─── STEP 2+3: FIX + VERIFY (mycelium-fix reads both, fixes, verifies) ───
if [ -f "mycelium-fix.cjs" ]; then
  node "mycelium-fix.cjs" --silent 2>/dev/null || true
fi

# ─── STEP 4: AUTO-MINE (incremental breakage pattern mining) ───
if [ -f "tools/mycelium-auto-mine.cjs" ]; then
  node "tools/mycelium-auto-mine.cjs" >/dev/null 2>&1
  MINE_EXIT=$?
  if [ "$MINE_EXIT" -ne 0 ]; then
    echo "  [mycelium] Mining failed (exit $MINE_EXIT) — run: node tools/mycelium-auto-mine.cjs --stats" >&2
  fi
fi

# ─── STEP 5: DATA QUALITY GATE (validate mined data stays premium) ───
# Silent on success. Alerts you on degradation or failure.
if [ -f "tools/validate-mined-data.cjs" ]; then
  node "tools/validate-mined-data.cjs" --fix 2>&1 | grep -i "\[MYCELIUM" >&2 || true
fi

# ─── STEP 6: SURFACE ALERTS (show .mycelium-alert if it exists) ───
if [ -f ".mycelium-alert" ]; then
  echo "" >&2
  cat ".mycelium-alert" >&2
  echo "" >&2
fi

# ─── STEP 7: TELEMETRY (commit-level time-series data collection) ───
if [ -f "tools/commit-telemetry.cjs" ]; then
  node "tools/commit-telemetry.cjs" --silent 2>/dev/null || true
fi

# ─── STEP 8: TEST TELEMETRY (correlate test results with commit) ───
if [ -f "tools/test-telemetry.cjs" ]; then
  node "tools/test-telemetry.cjs" --silent 2>/dev/null || true
fi

# ─── STEP 9: DEPENDENCY GRAPH (rebuild import graph on structural changes) ───
# Only rebuild if HTML or JS files changed (skip for docs/config-only commits)
CHANGED_EXTS=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null | grep -E '\.(html|js|css|ts|tsx)$' | head -1)
if [ -n "$CHANGED_EXTS" ] && [ -f "tools/dependency-graph.cjs" ]; then
  node "tools/dependency-graph.cjs" --silent 2>/dev/null || true
fi

# ─── BONUS: Fix commit? Also run postfix analysis + blame linking ───
COMMIT_MSG=$(git log -1 --pretty=format:"%s" 2>/dev/null)
case "$COMMIT_MSG" in
  fix*|Fix*|hotfix*|Hotfix*)
    if [ -f "mycelium-fix.cjs" ]; then
      node "mycelium-fix.cjs" --force >/dev/null 2>&1 || true
    fi
    if [ -f "mycelium.cjs" ]; then
      node mycelium.cjs --postfix >/dev/null 2>&1 || true
    fi
    # Incremental blame-link for this fix commit
    if [ -f "tools/blame-linker.cjs" ]; then
      node "tools/blame-linker.cjs" --recent 1 --silent 2>/dev/null || true
    fi
    # Compact: just 1 line instead of 4
    echo "  [mycelium] Fix detected — run: node mycelium.cjs --learned area lesson" >&2
    ;;
esac

# ─── STEP 10: EVENT BUS (process cross-system events into learnings) ───
if [ -f "tools/event-bus.cjs" ]; then
  node "tools/event-bus.cjs" process 2>/dev/null || true
fi

# ─── STEP 11: MEMORY TRIM (prevent unbounded growth) ───
# Only trim if memory.json > 200KB
MEM_SIZE=$(wc -c < .mycelium/memory.json 2>/dev/null || echo 0)
if [ "$MEM_SIZE" -gt 204800 ] && [ -f "tools/memory-trimmer.cjs" ]; then
  node "tools/memory-trimmer.cjs" 2>/dev/null || true
fi

exit 0
