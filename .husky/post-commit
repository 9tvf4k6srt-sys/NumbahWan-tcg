#!/bin/sh
# ═══════════════════════════════════════════════════════════════════
# Post-commit hook — single entrypoint, no silent failures.
# ═══════════════════════════════════════════════════════════════════
#
# All observers (watch, mycelium, fix, mine, validate, telemetry,
# test-telemetry, dependency-graph, event-bus, memory-trimmer) run
# through tools/observer-runner.cjs:
#   - parallel where possible
#   - bounded timeouts so a stuck observer never blocks a commit
#   - single summary written to .mycelium/observer-run.json
#   - failures captured in .mycelium/last-error.log
#   - structured event in .mycelium/events.jsonl
#
# Adding a new observer? Edit tools/observer-runner.cjs (REGISTRY +
# PROFILES). Every consumer (post-commit, post-merge, CI, factory)
# picks it up automatically. No copy-paste between hooks.
#
# Reusable pieces called here:
#   tools/observer-runner.cjs   ← this hook + post-merge + CI + factory
#   tools/event-bus.cjs         ← every system writes through it
#   tools/memory-trimmer.cjs    ← runs in observer profile + npm run trim
#   tools/system-health.cjs     ← reads observer-run.json + events.jsonl
# ═══════════════════════════════════════════════════════════════════

# Run all post-commit observers as one process. Exits 0 even on
# observer failure so git never blocks; details surface in stderr +
# .mycelium/last-error.log instead of being swallowed silently.
if [ -f "tools/observer-runner.cjs" ]; then
  node tools/observer-runner.cjs --hook=post-commit
fi

# Surface mycelium alerts (existing convention)
if [ -f ".mycelium-alert" ]; then
  echo "" >&2
  cat ".mycelium-alert" >&2
  echo "" >&2
fi

# Fix-commit bonus: postfix + blame-link the most recent commit so
# fix lessons are recorded against the breakages they resolve.
COMMIT_MSG=$(git log -1 --pretty=format:"%s" 2>/dev/null)
case "$COMMIT_MSG" in
  fix*|Fix*|hotfix*|Hotfix*)
    if [ -f "mycelium-fix.cjs" ]; then
      node mycelium-fix.cjs --force >/dev/null 2>>.mycelium/last-error.log || \
        echo "  [mycelium-fix] failed — see .mycelium/last-error.log" >&2
    fi
    if [ -f "mycelium.cjs" ]; then
      node mycelium.cjs --postfix >/dev/null 2>>.mycelium/last-error.log || \
        echo "  [mycelium --postfix] failed — see .mycelium/last-error.log" >&2
    fi
    if [ -f "tools/blame-linker.cjs" ]; then
      node tools/blame-linker.cjs --recent 1 --silent 2>>.mycelium/last-error.log || \
        echo "  [blame-linker] failed — see .mycelium/last-error.log" >&2
    fi
    echo "  [mycelium] Fix detected — run: node mycelium.cjs --learned area lesson" >&2
    ;;
esac

exit 0
