#!/bin/sh
# ═══════════════════════════════════════════════════════════════════
# Mycelium Pipeline: commit → WATCH → LEARN → FIX → VERIFY
# ═══════════════════════════════════════════════════════════════════
#
# Three roles, working in sync:
#   1. WATCHER:    mycelium-watch --learn (commit intelligence)
#   2. LEARNER:    mycelium snapshot (memory + constraints)
#   3. FIXER:      mycelium-fix (diagnose → prescribe → fix → verify)
#
# No manual intervention ever needed.
# ═══════════════════════════════════════════════════════════════════

# ─── STEP 1: WATCH + LEARN (both systems observe this commit) ───
if [ -f "mycelium-watch.cjs" ]; then
  node "mycelium-watch.cjs" --learn 2>/dev/null || true
fi
if [ -f "mycelium.cjs" ]; then
  node mycelium.cjs 2>/dev/null || true
  node mycelium.cjs --brief 2>/dev/null || true
fi

# ─── STEP 2+3: FIX + VERIFY (mycelium-fix reads both, fixes, verifies) ───
if [ -f "mycelium-fix.cjs" ]; then
  node "mycelium-fix.cjs" --silent 2>/dev/null || true
fi

# ─── BONUS: Fix commit? Also run postfix analysis ───
COMMIT_MSG=$(git log -1 --pretty=format:"%s" 2>/dev/null)
case "$COMMIT_MSG" in
  fix*|Fix*|hotfix*|Hotfix*)
    if [ -f "mycelium-fix.cjs" ]; then
      node "mycelium-fix.cjs" --force 2>/dev/null || true
    fi
    if [ -f "mycelium.cjs" ]; then
      node mycelium.cjs --postfix 2>/dev/null || true
    fi
    echo "" >&2
    echo "  FIX DETECTED — auto-fixed + verified. Record what you learned:" >&2
    echo "    node mycelium.cjs --learned \"area\" \"lesson\"" >&2
    echo "" >&2
    ;;
esac
exit 0
