{
  "project": {
    "name": "NumbahWan Guild",
    "codename": "webapp",
    "type": "cloudflare-pages-hono",
    "path": "/home/user/webapp",
    "description": "TCG/Gacha guild website with card forge, market, wallet system"
  },

  "tech_stack": {
    "framework": "Hono",
    "runtime": "Cloudflare Workers/Pages",
    "build": "Vite",
    "process_manager": "PM2",
    "language": "TypeScript",
    "styling": "Tailwind CSS (CDN) + Custom CSS"
  },

  "structure": {
    "entry": "src/index.tsx",
    "static_dir": "public/static/",
    "pages_dir": "public/",
    "data_dir": "public/static/data/",
    "dist_dir": "dist/",
    "config": ["wrangler.jsonc", "vite.config.ts", "ecosystem.config.cjs"]
  },

  "commands": {
    "build": "npm run build",
    "dev": "pm2 start ecosystem.config.cjs",
    "restart": "npm run build && pm2 restart all",
    "clean_restart": "fuser -k 3000/tcp 2>/dev/null; npm run build && pm2 restart all",
    "logs": "pm2 logs --nostream",
    "test": "curl http://localhost:3000/api/health"
  },

  "key_files": {
    "routing": {
      "file": "src/index.tsx",
      "static_pages_line": 1314,
      "note": "Add new HTML pages to staticPages array"
    },
    "card_system": {
      "renderer": "public/static/nw-card-renderer.js",
      "styles": "public/static/nw-card-frames.css",
      "reveal": "public/static/nw-card-reveal.css",
      "data": "public/static/data/cards.json",
      "logic": "public/static/nw-cards.js"
    },
    "wallet_system": {
      "script": "public/static/nw-wallet.js",
      "storage": "localStorage",
      "keys": ["nw_guest_id", "nw_forge_state", "nw_collection"]
    },
    "ui_system": {
      "core_css": "public/static/nw-core.css",
      "tokens": "public/static/nw-tokens.css",
      "utilities": "public/static/nw-utilities.css",
      "icons": "public/static/nw-icons-inline.js",
      "effects": "public/static/nw-effects.js"
    }
  },

  "pages": {
    "main": ["index.html", "tcg.html", "guide.html"],
    "features": ["forge.html", "market.html", "wallet.html", "cards.html"],
    "games": ["arcade.html", "fortune.html", "pvp.html"],
    "community": ["fashion.html", "memes.html", "merch.html", "apply.html"],
    "special": ["regina.html"],
    "dev": ["card-frames-demo.html", "test-render.html"]
  },

  "apis": {
    "health": "GET /api/health",
    "debug": "GET /api/debug",
    "cards": {
      "list": "GET /api/cards",
      "by_id": "GET /api/cards/:id",
      "by_rarity": "GET /api/cards/rarity/:rarity",
      "pull": "POST /api/cards/pull"
    },
    "market": {
      "listings": "GET /api/market/listings",
      "buy": "POST /api/market/buy",
      "list": "POST /api/market/list"
    }
  },

  "gotchas": [
    "ALWAYS use 'hono/cloudflare-workers' for serveStatic, NOT '@hono/node-server/serve-static'",
    "Static pages must be added to staticPages array in src/index.tsx:1314",
    "Build BEFORE restart - wrangler serves from dist/ not public/",
    "No fs module - Cloudflare Workers has no filesystem access at runtime",
    "Card images in public/static/cards/ - some in subdirs (legendary/, epic/, etc.)",
    "PM2 is pre-installed - always use it for service management",
    "Port 3000 - kill before restart: fuser -k 3000/tcp"
  ],

  "card_system_notes": {
    "rendering": "NW_CARDS.render(cardData, {size: 'sm'|'md'|'lg'})",
    "batch": "NW_CARDS.renderCards(array, '#container', options)",
    "rarities": ["mythic", "legendary", "epic", "rare", "uncommon", "common"],
    "z_index_order": {
      "outer_glow": "-1 to 0",
      "shimmer": "1",
      "card_inner": "2",
      "frame_border": "3", 
      "ui_elements": "10-15"
    },
    "image_path": "/static/cards/{filename}.jpg",
    "stats_auto_generated": "If card has no stats, auto-generates based on rarity"
  }
}
