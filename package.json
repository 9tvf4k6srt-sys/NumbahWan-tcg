{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "node nw-memory.cjs --brief && vite",
    "build": "vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "dev:d1": "wrangler pages dev dist --d1=GUILD_DB --local --persist-to=.wrangler/state --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply numbahwan-guild-db --local --persist-to=.wrangler/state",
    "db:seed": "wrangler d1 execute numbahwan-guild-db --local --persist-to=.wrangler/state --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state && npm run db:migrate:local && npm run db:seed",
    "db:console": "wrangler d1 execute numbahwan-guild-db --local --persist-to=.wrangler/state",
    "cards:thumbs": "./scripts/card-manager.sh thumbs",
    "cards:verify": "./scripts/card-manager.sh verify",
    "cards:stats": "./scripts/card-manager.sh stats",
    "cards:list": "./scripts/card-manager.sh list",
    "cards:tabletop": "node scripts/generate-tabletop-stats.cjs",
    "cards:tabletop:preview": "node scripts/generate-tabletop-stats.cjs --preview",

    "media:download": "node ./scripts/download-media.js",
    "media:compress": "./scripts/media-utils.sh compress-images",
    "media:icons": "./scripts/media-utils.sh compress-icons",
    "media:audio": "./scripts/media-utils.sh compress-audio",
    "media:pipeline": "./scripts/process-media.sh",

    "ui:validate": "node scripts/ui-validator.js",
    "ui:validate:cards": "node scripts/ui-validator.js public/cards.html",
    "sentinel": "node sentinel.cjs",
    "sentinel:ci": "node sentinel.cjs --ci",
    "sentinel:fix": "node sentinel.cjs --fix",
    "sentinel:json": "node sentinel.cjs --json",
    "prebuild": "node sentinel.cjs",
    "test": "node tests/run-tests.cjs",
    "test:api": "node tests/run-tests.cjs --api",
    "test:html": "node tests/run-tests.cjs --html",
    "test:perf": "node tests/run-tests.cjs --perf",
    "test:arch": "node tests/run-tests.cjs --arch",
    "test:data": "node tests/run-tests.cjs --data",
    "memory": "node nw-memory.cjs --query",
    "memory:health": "node nw-memory.cjs --health"
  },
  "dependencies": {
    "hono": "^4.11.5",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/vite": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.1.18",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
