{
  "name": "mycelium",
  "type": "module",
  "description": "Codebase Immune System — learns from every commit, remembers every breakage, strengthens every constraint",
  "bin": {
    "mycelium": "./bin/mycelium.cjs"
  },
  "scripts": {
    "dev": "node mycelium.cjs --brief && vite",
    "build": "node sentinel.cjs --json > public/static/data/sentinel-report.json 2>/dev/null; node scripts/generate-showcase-data.cjs 2>/dev/null; node tools/page-weight-profiler.cjs 2>/dev/null; vite build && node post-build.cjs && node tools/commit-telemetry.cjs --build --silent 2>/dev/null",
    "preview": "node scripts/preview-deploy.cjs",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "dev:d1": "wrangler pages dev dist --d1=GUILD_DB --local --persist-to=.wrangler/state --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply numbahwan-guild-db --local --persist-to=.wrangler/state",
    "db:seed": "wrangler d1 execute numbahwan-guild-db --local --persist-to=.wrangler/state --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state && npm run db:migrate:local && npm run db:seed",
    "db:console": "wrangler d1 execute numbahwan-guild-db --local --persist-to=.wrangler/state",
    "cards:thumbs": "./scripts/card-manager.sh thumbs",
    "cards:verify": "./scripts/card-manager.sh verify",
    "cards:stats": "./scripts/card-manager.sh stats",
    "cards:list": "./scripts/card-manager.sh list",
    "cards:tabletop": "node scripts/generate-tabletop-stats.cjs",
    "cards:tabletop:preview": "node scripts/generate-tabletop-stats.cjs --preview",
    "media:download": "node ./scripts/download-media.js",
    "media:compress": "./scripts/media-utils.sh compress-images",
    "media:icons": "./scripts/media-utils.sh compress-icons",
    "media:audio": "./scripts/media-utils.sh compress-audio",
    "media:pipeline": "./scripts/process-media.sh",
    "guardian": "node sentinel.cjs",
    "guardian:ci": "node sentinel.cjs --ci",
    "guardian:heal": "node sentinel.cjs --heal",
    "guardian:guard": "node sentinel.cjs --guard",
    "guardian:json": "node sentinel.cjs --json",
    "guardian:manifest": "node sentinel.cjs --manifest",
    "guardian:trend": "node sentinel.cjs --trend",
    "guardian:fix": "node sentinel.cjs --auto-fix",
    "prebuild": "node sentinel.cjs",
    "test": "node tests/run-tests.cjs",
    "test:api": "node tests/run-tests.cjs --api",
    "test:html": "node tests/run-tests.cjs --html",
    "test:perf": "node tests/run-tests.cjs --perf",
    "test:arch": "node tests/run-tests.cjs --arch",
    "test:data": "node tests/run-tests.cjs --data",
    "test:i18n": "node tests/nw-i18n-guard.cjs",
    "test:i18n:home": "node tests/nw-i18n-guard.cjs index.html",
    "test:i18n:verbose": "node tests/nw-i18n-guard.cjs --verbose",
    "test:i18n:fix": "node tests/nw-i18n-guard.cjs --fix",
    "test:i18n:fix:dry": "node tests/nw-i18n-guard.cjs --fix --dry-run",
    "test:i18n:report": "node tests/nw-i18n-guard.cjs --fix-report",
    "mycelium": "node bin/mycelium.cjs",
    "mycelium:eval": "node bin/mycelium.cjs eval",
    "mycelium:fix": "node bin/mycelium.cjs fix",
    "mycelium:health": "node bin/mycelium.cjs health",
    "mycelium:ship": "node bin/mycelium.cjs ship",
    "agent": "node bin/agent-brief.cjs",
    "agent:quick": "node bin/agent-brief.cjs --quick",
    "agent:onboard": "node bin/agent-brief.cjs --onboard",
    "agent:rules": "node bin/agent-brief.cjs --rules",
    "agent:health": "node bin/agent-brief.cjs --health",
    "visual:test": "backstop test --config=backstop.config.cjs",
    "visual:approve": "backstop approve --config=backstop.config.cjs",
    "visual:reference": "backstop reference --config=backstop.config.cjs",
    "preview:branch": "node scripts/preview-deploy.cjs",
    "test:smoke": "node tests/smoke-test.cjs",
    "test:smoke:verbose": "node tests/smoke-test.cjs --verbose",
    "telemetry": "node tools/commit-telemetry.cjs --report",
    "telemetry:trend": "node tools/commit-telemetry.cjs --trend",
    "telemetry:stats": "node tools/commit-telemetry.cjs --stats",
    "telemetry:json": "node tools/commit-telemetry.cjs --json",
    "telemetry:export": "node tools/commit-telemetry.cjs --export",
    "telemetry:collect": "node tools/commit-telemetry.cjs",
    "mine:areas": "node tools/area-config-gen.cjs",
    "mine:blame": "node tools/blame-linker.cjs",
    "mine:blame:stats": "node tools/blame-linker.cjs --stats",
    "mine:blame:recent": "node tools/blame-linker.cjs --recent 20",
    "mine:weights": "node tools/page-weight-profiler.cjs",
    "mine:weights:budget": "node tools/page-weight-profiler.cjs --budget",
    "mine:tests": "node tools/test-telemetry.cjs",
    "mine:tests:report": "node tools/test-telemetry.cjs --report",
    "mine:prs": "node tools/pr-miner.cjs",
    "mine:prs:stats": "node tools/pr-miner.cjs --stats",
    "mine:graph": "node tools/dependency-graph.cjs",
    "mine:graph:stats": "node tools/dependency-graph.cjs --stats",
    "mine:graph:impact": "node tools/dependency-graph.cjs --impact",
    "mine:all": "node tools/area-config-gen.cjs && node tools/page-weight-profiler.cjs && node tools/dependency-graph.cjs && node tools/blame-linker.cjs && node tools/test-telemetry.cjs && node tools/pr-miner.cjs && node tools/commit-telemetry.cjs"
  },
  "dependencies": {
    "hono": "^4.11.5",
    "js-yaml": "^4.1.1",
    "openai": "^6.21.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "backstopjs": "^6.3.25",
    "qrcode": "^1.5.4",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
