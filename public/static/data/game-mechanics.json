{
  "version": "2.0.0",
  "gameName": "NumbahWan TCG: Guild Wars",
  "tagline": "We are not just a guild, but FAMILY... that fights!",
  "designPhilosophy": "High variance gambling mechanics + skill expression = content gold",

  "coreRules": {
    "objective": "Reduce opponent's Guild HP from 30 to 0 (or deck them out)",
    "deckSize": { "min": 20, "max": 30, "recommended": 25 },
    "handSize": { "starting": 5, "max": 10 },
    "energySystem": {
      "starting": 1,
      "maxEnergy": 10,
      "gainPerTurn": 1,
      "note": "Energy fully refills each turn - spent energy resets"
    },
    "boardSlots": {
      "members": 5,
      "gearPerMember": 2,
      "vibesActive": 3,
      "spotsActive": 1
    },
    "turnTimeLimit": 60,
    "winConditions": [
      "Reduce opponent Guild HP to 0",
      "Opponent cannot draw (deck out)",
      "Special card win conditions (rare)"
    ]
  },

  "cardTypes": {
    "member": {
      "icon": "👤",
      "description": "Guild members that fight on the board",
      "canAttack": true,
      "hasHP": true,
      "persistent": true,
      "maxOnBoard": 5,
      "summoningSickness": true,
      "note": "Members can't attack the turn they're played (unless they have RUSH)"
    },
    "moment": {
      "icon": "⚡",
      "description": "Instant effects that trigger immediately and discard",
      "canAttack": false,
      "hasHP": false,
      "persistent": false,
      "subtypes": ["damage", "heal", "draw", "buff", "removal", "counter"]
    },
    "gear": {
      "icon": "⚔️",
      "description": "Equipment that buffs members permanently",
      "canAttack": false,
      "attachesTo": "member",
      "persistent": true,
      "destroyed": "When attached member dies",
      "note": "Gear stays on member until member is destroyed"
    },
    "vibe": {
      "icon": "🌀",
      "description": "Persistent effects that last multiple turns",
      "duration": { "min": 2, "max": 4 },
      "affectsBoard": true,
      "stackable": true,
      "note": "Multiple vibes can be active - they stack!"
    },
    "spot": {
      "icon": "📍",
      "description": "Locations that affect the entire board",
      "affectsAll": true,
      "persistent": true,
      "maxActive": 1,
      "note": "Playing a new spot destroys the old one"
    }
  },

  "cardStats": {
    "ATK": {
      "icon": "⚔️",
      "color": "#ef4444",
      "description": "Damage dealt when attacking",
      "formula": "Base ATK + Gear + Buffs - Debuffs"
    },
    "HP": {
      "icon": "❤️",
      "color": "#22c55e",
      "description": "Health points - card dies at 0",
      "healing": "Can heal but never exceed max HP"
    },
    "COST": {
      "icon": "💎",
      "color": "#3b82f6",
      "description": "Energy required to play",
      "costReduction": "Some effects reduce cost (min 0)"
    },
    "SPD": {
      "icon": "💨",
      "color": "#fbbf24",
      "description": "Attack order priority",
      "tiebreaker": "If tied, defender chooses order"
    },
    "CRIT": {
      "icon": "💥",
      "color": "#f97316",
      "description": "% chance to deal DOUBLE damage",
      "max": 50,
      "note": "Crits bypass TAUNT and ignore 50% of ARMOR"
    },
    "DODGE": {
      "icon": "🌀",
      "color": "#8b5cf6",
      "description": "% chance to completely avoid an attack",
      "max": 40,
      "note": "Dodge can trigger on abilities too (not just attacks)"
    }
  },

  "gamblingMechanics": {
    "philosophy": "Every game should have at least 2-3 'clip-worthy' RNG moments",
    
    "criticalHits": {
      "baseChance": "Determined by card's CRIT stat (0-50%)",
      "effect": "Deal 2x damage",
      "visualEffect": "Screen shake + gold flash",
      "soundEffect": "Epic CRITICAL hit sound",
      "commentatorMoment": "THE CRIT! HE CRITS FOR THE WIN!"
    },
    
    "dodges": {
      "baseChance": "Determined by card's DODGE stat (0-40%)",
      "effect": "Take 0 damage from attack",
      "visualEffect": "Afterimage + whoosh",
      "soundEffect": "Matrix dodge sound",
      "commentatorMoment": "THE DODGE! THEY DODGED AT 1 HP!"
    },
    
    "rngCards": {
      "description": "Cards with explicitly random effects",
      "examples": {
        "Server Crash": "50% destroy all enemies OR 50% destroy all allies",
        "Gacha Victim": "Summon random member from entire card pool",
        "Ninja Loot": "Steal random card from opponent's hand",
        "Accidental Pull": "50% pull legendary, 50% pull common from deck",
        "Coin Flip": "Call heads/tails - winner draws 3, loser discards 2"
      },
      "designNote": "RNG cards should be high risk/high reward - never just upside"
    },
    
    "comebackMechanics": {
      "CLUTCH": {
        "trigger": "Guild HP below 10",
        "effect": "+5 ATK to CLUTCH cards",
        "note": "Creates tense endgame scenarios"
      },
      "PITY_SYSTEM": {
        "trigger": "Lost 3 games in a row",
        "effect": "Start next game with +5 Guild HP and draw +1 card",
        "note": "Prevents tilt from losing streaks"
      },
      "UNDERDOG_BONUS": {
        "trigger": "Opponent has 3+ more cards on board",
        "effect": "Your cards have +1 ATK",
        "note": "Helps prevent blowouts"
      }
    },
    
    "highlightMoments": {
      "design": "These scenarios are designed for content creation",
      "moments": [
        "Last card topdeck lethal",
        "Triple crit chain for exact lethal",
        "Dodge at 1 HP to survive",
        "Server Crash 50/50 deciding the game",
        "Pulling mythic from Gacha Victim",
        "Comeback from 5 HP with CLUTCH cards",
        "Perfect 10-card combo"
      ]
    }
  },

  "turnStructure": {
    "phases": [
      {
        "name": "START PHASE",
        "icon": "🌅",
        "actions": [
          "Start-of-turn effects trigger",
          "Vibe durations tick down",
          "GRINDER cards gain +1/+1"
        ]
      },
      {
        "name": "DRAW PHASE",
        "icon": "🎴",
        "actions": [
          "Draw 1 card",
          "Going second on turn 1? Draw 2 instead",
          "If deck empty, take 1 FATIGUE damage (increases each turn)"
        ]
      },
      {
        "name": "ENERGY PHASE",
        "icon": "💎",
        "actions": [
          "Gain +1 max energy (up to 10)",
          "Refill all energy to max",
          "Some cards modify energy gain"
        ]
      },
      {
        "name": "MAIN PHASE",
        "icon": "🎮",
        "actions": [
          "Play cards from hand (spend energy)",
          "Use member abilities",
          "Attach gear to members",
          "Activate vibes and spots",
          "No limit on actions"
        ]
      },
      {
        "name": "COMBAT PHASE",
        "icon": "⚔️",
        "actions": [
          "Declare attackers (members without summoning sickness)",
          "Choose targets (enemy members or Guild HP)",
          "Attacks resolve in SPD order (highest first)",
          "TAUNT must be attacked first",
          "CRIT and DODGE rolls happen here"
        ]
      },
      {
        "name": "END PHASE",
        "icon": "🌙",
        "actions": [
          "End-of-turn effects trigger",
          "AFK cards regenerate HP",
          "Discard down to 10 cards",
          "Pass turn to opponent"
        ]
      }
    ]
  },

