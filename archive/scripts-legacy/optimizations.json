{
  "version": "1.0.0",
  "lastRun": null,
  "history": [],
  "rules": {
    "images": {
      "maxSize": 512000,
      "thumbWidth": 320,
      "thumbQuality": 80,
      "formats": ["webp", "avif"],
      "autoGenerate": true
    },
    "code": {
      "maxConsoleLog": 10,
      "removeDeadCode": false,
      "minifyProduction": true
    },
    "data": {
      "singleSource": true,
      "validateJson": true,
      "minifyProduction": true
    },
    "security": {
      "noHardcodedSecrets": true,
      "requireGitignore": true,
      "sensitivePatterns": [
        "api_key",
        "apikey",
        "secret",
        "password",
        "token",
        "private_key"
      ]
    },
    "performance": {
      "maxBundleSize": 1048576,
      "lazyLoadImages": true,
      "asyncScripts": true
    }
  },
  "autoFixes": {
    "thumbnails": {
      "enabled": true,
      "command": "./scripts/card-manager.sh thumbs"
    },
    "paths": {
      "enabled": true,
      "patterns": [
        {
          "find": "/static/cards/",
          "replace": "/static/images/cards/"
        }
      ]
    },
    "gitignore": {
      "enabled": true,
      "required": [
        "node_modules",
        ".env",
        ".dev.vars",
        ".wrangler",
        "dist"
      ]
    }
  },
  "suggestions": []
}
